//@version=6
// ORB-VWAP Universal | Longs + Shorts | Any Symbol | Any Timeframe
strategy("ORB-VWAP Universal",
     overlay=true,
     initial_capital=25000, currency=currency.USD,
     margin_long=25, margin_short=25,
     default_qty_type=strategy.fixed, default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=0, slippage=1, calc_on_every_tick=false)

i_maxRisk   = input.float(250.0, "Risk Per Trade ($)",   minval=25.0,  step=25.0)
i_maxDay    = input.float(500.0, "Max Day Loss ($)",     minval=100.0, step=50.0)
i_atrMult   = input.float(1.5,   "ATR Stop Mult",        minval=0.5,   step=0.25)
i_useHTF    = input.bool(true,   "1H Trend Filter")
i_volMax    = input.float(1.0,   "Max ORB Vol vs avg",   minval=0.3,   step=0.1)
i_trailAct  = input.float(0.5,   "Trail activate (×R)",  minval=0.25,  step=0.25)
i_trailOff  = input.float(0.5,   "Trail offset (×R)",    minval=0.25,  step=0.25)
i_orbHour   = input.int(9,    "ORB Open Hour (ET)",      minval=0, maxval=23)
i_orbMin    = input.int(30,   "ORB Open Minute (ET)",    minval=0, maxval=59)
i_useSess   = input.bool(false,  "Use Session Filter")
i_sessStart = input.int(945,  "Session start (HHMM ET)", minval=0, maxval=2359)
i_sessEnd   = input.int(1500, "Session end   (HHMM ET)", minval=0, maxval=2359)
i_eodClose  = input.int(1530, "EOD Close     (HHMM ET)", minval=0, maxval=2359)
i_longs     = input.bool(true,   "Enable Longs")
i_shorts    = input.bool(true,   "Enable Shorts")

htfClose = request.security(syminfo.tickerid, "60", close,             lookahead=barmerge.lookahead_off)
htfEma20 = request.security(syminfo.tickerid, "60", ta.ema(close, 20), lookahead=barmerge.lookahead_off)
htfRsi14 = request.security(syminfo.tickerid, "60", ta.rsi(close, 14), lookahead=barmerge.lookahead_off)
htfBull  = not i_useHTF or (htfClose > htfEma20 and htfRsi14 > 50)
htfBear  = not i_useHTF or (htfClose < htfEma20 and htfRsi14 < 50)

prevDayClose = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_off)

vwapVal = ta.vwap
atrVal  = ta.atr(14)

nyHour   = hour(time,   "America/New_York")
nyMinute = minute(time, "America/New_York")
nyTotalM = nyHour * 60 + nyMinute
isOpen   = nyHour == i_orbHour and nyMinute == i_orbMin
orbOrbM  = i_orbHour * 60 + i_orbMin

sessStartM = (i_sessStart / 100) * 60 + (i_sessStart % 100)
sessEndM   = (i_sessEnd   / 100) * 60 + (i_sessEnd   % 100)
eodM       = (i_eodClose  / 100) * 60 + (i_eodClose  % 100)

var float[] orbVols = array.new_float(0)
var float   prevOrbV = na
var bool    volOk    = false
var bool    orbBull  = false
var bool    orbBear  = false

if isOpen
    if not na(prevOrbV)
        array.push(orbVols, prevOrbV)
        if array.size(orbVols) > 20
            array.shift(orbVols)
    orbAvg   = array.size(orbVols) >= 5 ? array.avg(orbVols) : na
    volOk   := not na(orbAvg) and volume < orbAvg * i_volMax
    prevOrbV := volume
    orbBull  := close > open
    orbBear  := close < open

var float orbH = na
var float orbL = na
if isOpen
    orbH := high
    orbL := low

orbFormed = not na(orbH) and nyTotalM > orbOrbM
inSession = not i_useSess or (nyTotalM >= sessStartM and nyTotalM < sessEndM)

var float dayEq   = na
var bool  dayDead = false
if isOpen
    dayEq   := strategy.equity
    dayDead := false
if not na(dayEq) and (strategy.equity - dayEq) < -i_maxDay
    dayDead := true

noPos      = strategy.position_size == 0
atrOk      = not na(atrVal) and atrVal > 0
entryBull  = close > open
entryBear  = close < open
abovePrev  = not na(prevDayClose) and close > prevDayClose
belowPrev  = not na(prevDayClose) and close < prevDayClose
aboveVWAP  = close > vwapVal
belowVWAP  = close < vwapVal
aboveORBH  = close > orbH
belowORBL  = close < orbL

ok = noPos and not dayDead and orbFormed and atrOk and volOk and inSession

longSig  = i_longs  and ok and aboveORBH and aboveVWAP and htfBull and orbBull and entryBull and abovePrev
shortSig = i_shorts and ok and belowORBL and belowVWAP and htfBear and orbBear and entryBear and belowPrev

stopDist    = math.max(atrVal * i_atrMult, syminfo.mintick * 10)
stopDollars = stopDist * syminfo.pointvalue
qty         = math.min(math.max(math.floor(i_maxRisk / stopDollars), 1), 200)
stopTicks   = math.round(stopDist / syminfo.mintick)
trailPoints = math.round(stopDist * i_trailAct / syminfo.mintick)
trailOffset = math.round(stopDist * i_trailOff / syminfo.mintick)

if longSig
    strategy.entry("L", strategy.long,  qty=qty)
    strategy.exit("Lx", "L", loss=stopTicks, trail_points=trailPoints, trail_offset=trailOffset)

if shortSig
    strategy.entry("S", strategy.short, qty=qty)
    strategy.exit("Sx", "S", loss=stopTicks, trail_points=trailPoints, trail_offset=trailOffset)

if i_useSess and nyTotalM >= eodM and not noPos
    strategy.close_all("EOD")

plot(vwapVal,               "VWAP",  color.purple,              linewidth=2)
plot(orbFormed ? orbH : na, "ORB H", color.new(color.green,40), linewidth=1, style=plot.style_stepline)
plot(orbFormed ? orbL : na, "ORB L", color.new(color.red,  40), linewidth=1, style=plot.style_stepline)
if longSig
    label.new(bar_index, low,  "▲ BUY",  color=color.green, textcolor=color.white, style=label.style_label_up,   size=size.normal)
if shortSig
    label.new(bar_index, high, "▼ SELL", color=color.red,   textcolor=color.white, style=label.style_label_down, size=size.normal)

// ── Dashboard (top-right, live pass/fail per filter) ───────────────────────
var table dash = table.new(position.top_right, 2, 13,
     bgcolor=color.new(color.black, 55),
     border_color=color.new(color.gray, 50), border_width=1,
     frame_color=color.new(color.gray, 50),  frame_width=1)

C_PASS = color.new(color.green, 25)
C_FAIL = color.new(color.red,   25)
C_INFO = color.new(color.gray,  55)
C_HEAD = color.new(color.navy,  15)

_cell(col, row, txt, bg) =>
    table.cell(dash, col, row, txt, bgcolor=bg, text_color=color.white,
         text_size=size.small, text_halign=col == 0 ? text.align_left : text.align_center)

// Row 0: header
_cell(0, 0, "Filter",                               C_HEAD)
_cell(1, 0, syminfo.ticker + " " + timeframe.period, C_HEAD)

// Rows 1-10: filters
_cell(0,  1, "1H Trend (HTF)",    C_INFO)
_cell(1,  1, htfBull ? "BULL ✓" : htfBear ? "BEAR ✓" : "NONE ✗",           htfBull or htfBear ? C_PASS : C_FAIL)

_cell(0,  2, "ORB Formed",        C_INFO)
_cell(1,  2, orbFormed ? "✓" : "waiting…",                                    orbFormed ? C_PASS : C_FAIL)

_cell(0,  3, "ORB Candle",        C_INFO)
_cell(1,  3, orbBull ? "BULL ✓" : orbBear ? "BEAR ✓" : "–",                  orbBull or orbBear ? C_PASS : C_FAIL)

_cell(0,  4, "Entry Bar",         C_INFO)
_cell(1,  4, entryBull ? "BULL" : "BEAR",                                     C_INFO)

_cell(0,  5, "vs Prev Close",     C_INFO)
_cell(1,  5, abovePrev ? "ABOVE ✓" : belowPrev ? "BELOW ✓" : "✗",           abovePrev or belowPrev ? C_PASS : C_FAIL)

_cell(0,  6, "VWAP",              C_INFO)
_cell(1,  6, aboveVWAP ? "ABOVE" : "BELOW",                                   C_INFO)

_cell(0,  7, "ORB Breakout",      C_INFO)
_cell(1,  7, aboveORBH ? "ABOVE H ✓" : belowORBL ? "BELOW L ✓" : "inside ✗", aboveORBH or belowORBL ? C_PASS : C_FAIL)

_cell(0,  8, "Volume",            C_INFO)
_cell(1,  8, volOk ? "OK ✓" : na(prevOrbV) ? "warmup…" : "HIGH ✗",           volOk ? C_PASS : C_FAIL)

_cell(0,  9, "Session",           C_INFO)
_cell(1,  9, inSession ? "✓" : "✗",                                           inSession ? C_PASS : C_FAIL)

_cell(0, 10, "Day P&L",           C_INFO)
_cell(1, 10, not dayDead ? "OK ✓" : "LIMIT ✗",                               not dayDead ? C_PASS : C_FAIL)

_cell(0, 11, "Position",          C_INFO)
_cell(1, 11, noPos ? "flat ✓" : "in trade",                                   noPos ? C_PASS : C_INFO)

// Row 12: signal readiness
sigBg  = longSig  ? C_PASS : shortSig ? color.new(color.orange, 20) : C_FAIL
sigTxt = longSig  ? "▲ BUY NOW" : shortSig ? "▼ SELL NOW" : "NO SIGNAL"
_cell(0, 12, "SIGNAL",  sigBg)
_cell(1, 12, sigTxt,    sigBg)
