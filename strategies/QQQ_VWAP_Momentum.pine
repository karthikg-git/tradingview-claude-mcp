//@version=6
strategy("QQQ VWAP Momentum 15min",
     overlay=true, initial_capital=5000, currency=currency.USD,
     default_qty_type=strategy.fixed, default_qty_value=1,
     commission_type=strategy.commission.percent, commission_value=0.05,
     slippage=2, calc_on_every_tick=false)

// ─── INPUTS ──────────────────────────────────────────────────────────
i_rr       = input.float(2.0, "R:R Ratio",           minval=1.0, step=0.5)
i_atrMult  = input.float(1.0, "ATR Stop Multiplier", minval=0.25, step=0.25)
i_rsiLen   = input.int(14,    "RSI Length",           minval=5)
i_rsiLong  = input.float(50.0, "RSI Long  ≥",        minval=45.0, maxval=60.0, step=1.0)
i_rsiShort = input.float(50.0, "RSI Short ≤",        minval=40.0, maxval=55.0, step=1.0)

// ─── INDICATORS ───────────────────────────────────────────────────────
vwapVal = ta.vwap
ema9    = ta.ema(close, 9)
rsiVal  = ta.rsi(close, i_rsiLen)
atrVal  = ta.atr(14)

// ─── ORB (1 bar = 15-min opening range) ──────────────────────────────
nyHour   = hour(time, "America/New_York")
nyMinute = minute(time, "America/New_York")
nyTotal  = nyHour * 60 + nyMinute

isMarketOpen = nyHour == 9 and nyMinute == 30

var float orbHigh = na
var float orbLow  = na

if isMarketOpen
    orbHigh := high
    orbLow  := low

orbFormed = not na(orbHigh) and nyTotal > 9*60+30

// ─── SESSION: 9:45 AM – 3:30 PM ET ───────────────────────────────────
inSession = nyTotal >= 9*60+45 and nyTotal < 15*60+30

// ─── SIGNALS ──────────────────────────────────────────────────────────
noPos = strategy.position_size == 0

longSig  = inSession and noPos and orbFormed
         and close > vwapVal
         and close > ema9
         and close > orbHigh
         and rsiVal >= i_rsiLong

shortSig = inSession and noPos and orbFormed
         and close < vwapVal
         and close < ema9
         and close < orbLow
         and rsiVal <= i_rsiShort

// ─── SIZING: risk $100 per trade ─────────────────────────────────────
stopDist = math.max(nz(atrVal, 1.5) * i_atrMult, 0.05)
qty      = math.max(math.floor(100.0 / stopDist), 1)

// ─── EXECUTION ────────────────────────────────────────────────────────
if longSig
    ep = close
    strategy.entry("Long", strategy.long, qty=qty)
    strategy.exit("L-x", "Long", stop=ep - stopDist, limit=ep + stopDist * i_rr)

if shortSig
    ep = close
    strategy.entry("Short", strategy.short, qty=qty)
    strategy.exit("S-x", "Short", stop=ep + stopDist, limit=ep - stopDist * i_rr)

// EOD: close everything at 3:30 PM ET
if nyHour == 15 and nyMinute >= 30
    strategy.close_all("EOD")

// ─── PLOTS ────────────────────────────────────────────────────────────
plot(series=vwapVal,                  title="VWAP",  color=color.purple,              linewidth=2)
plot(series=ema9,                     title="EMA9",  color=color.new(color.blue, 30), linewidth=1)
plot(series=orbFormed ? orbHigh : na, title="ORB H", color=color.new(color.green, 30), linewidth=1, style=plot.style_stepline)
plot(series=orbFormed ? orbLow  : na, title="ORB L", color=color.new(color.red,   30), linewidth=1, style=plot.style_stepline)

if longSig
    label.new(bar_index, low,  "L", color=color.green, textcolor=color.white, style=label.style_label_up,   size=size.tiny)
if shortSig
    label.new(bar_index, high, "S", color=color.red,   textcolor=color.white, style=label.style_label_down, size=size.tiny)
