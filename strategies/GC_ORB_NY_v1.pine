//@version=6
strategy("GC ORB NY v1", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1,
     commission_value=8, commission_type=strategy.commission.cash_per_order,
     margin_long=8, margin_short=8, initial_capital=25000)

// ── Inputs ────────────────────────────────────────────────────────────────────
i_maxRisk  = input.float(250.0, "Max Risk $",   minval=50)
i_trailAct = input.float(0.5,   "Trail Act (R)", minval=0.1, step=0.1)
i_trailOff = input.float(0.5,   "Trail Off (R)", minval=0.1, step=0.1)
i_volMax   = input.float(1.5,   "Vol Ratio Max", minval=0.5, step=0.1)
i_useHTF   = input.bool(true,   "Use 1H HTF Filter")
i_minATR   = input.float(5.0,   "Min ATR (pts)", minval=1.0)

// ── Backtest window ───────────────────────────────────────────────────────────
inBT = time >= timestamp("2025-04-19T00:00:00-05:00")
if not inBT and strategy.position_size != 0
    strategy.close_all()

// ── Session time (ET) ─────────────────────────────────────────────────────────
nyHour   = hour(time, "America/New_York")
nyMinute = minute(time, "America/New_York")
nyTotal  = nyHour * 60 + nyMinute

isOpen        = nyHour == 9 and nyMinute == 30
inORBWindow   = nyTotal >= 570 and nyTotal < 600
inEntryWindow = nyTotal >= 600 and nyTotal < 660

// ── ORB state ─────────────────────────────────────────────────────────────────
var float orbHigh   = na
var float orbLow    = na
var bool  orbFormed = false
var bool  orbBull   = false
var bool  orbBear   = false
var bool  dayDead   = false

if isOpen
    orbHigh   := high
    orbLow    := low
    orbFormed := false
    orbBull   := close > open
    orbBear   := close < open
    dayDead   := false

if inORBWindow and not isOpen
    orbHigh := math.max(orbHigh, high)
    orbLow  := math.min(orbLow,  low)

if nyTotal >= 600 and not orbFormed
    orbFormed := true

// ── VWAP (daily reset) ────────────────────────────────────────────────────────
var float vwapN = 0.0
var float vwapD = 0.0

if isOpen
    vwapN := hlc3 * volume
    vwapD := volume
else if inORBWindow or inEntryWindow
    vwapN += hlc3 * volume
    vwapD += volume

vwap = vwapD > 0 ? vwapN / vwapD : na

// ── HTF filter (1H) ───────────────────────────────────────────────────────────
htfEMA = request.security(syminfo.tickerid, "60", ta.ema(close, 20), lookahead=barmerge.lookahead_off)
htfOkL = close > htfEMA
htfOkS = close < htfEMA

// ── ATR filter ────────────────────────────────────────────────────────────────
atr14 = ta.atr(14)
atrOk = atr14 >= i_minATR

// ── Volume filter (20-day rolling avg of ORB bars) ────────────────────────────
var float[] volArr = array.new_float(0)
if isOpen
    array.push(volArr, volume)
    if array.size(volArr) > 20
        array.shift(volArr)

volAvg = array.size(volArr) >= 5 ? array.avg(volArr) : na
volOk  = na(volAvg) or volume <= volAvg * i_volMax

// ── Entry conditions ──────────────────────────────────────────────────────────
canEnter  = orbFormed and inEntryWindow and strategy.position_size == 0 and not dayDead and inBT

longCond  = canEnter and orbBull and close > orbHigh and close > vwap and
            (not i_useHTF or htfOkL) and atrOk and volOk

shortCond = canEnter and orbBear and close < orbLow  and close < vwap and
            (not i_useHTF or htfOkS) and atrOk and volOk

// ── Position sizing ───────────────────────────────────────────────────────────
longStopDist  = not na(orbLow)  ? math.max(close - orbLow,  syminfo.mintick) : syminfo.mintick
shortStopDist = not na(orbHigh) ? math.max(orbHigh - close, syminfo.mintick) : syminfo.mintick

calcQty(stopDist) =>
    dollars = stopDist * syminfo.pointvalue
    math.max(1, math.min(math.floor(i_maxRisk / dollars), 10))

longQty  = calcQty(longStopDist)
shortQty = calcQty(shortStopDist)

// ── Entries ───────────────────────────────────────────────────────────────────
if longCond
    strategy.entry("Long", strategy.long, qty=longQty)
    dayDead := true
    lT = math.round(longStopDist / syminfo.mintick)
    strategy.exit("LX", "Long",
         loss         = lT,
         trail_points = math.round(i_trailAct * longStopDist  / syminfo.mintick),
         trail_offset = math.round(i_trailOff * longStopDist  / syminfo.mintick))

if shortCond
    strategy.entry("Short", strategy.short, qty=shortQty)
    dayDead := true
    sT = math.round(shortStopDist / syminfo.mintick)
    strategy.exit("SX", "Short",
         loss         = sT,
         trail_points = math.round(i_trailAct * shortStopDist / syminfo.mintick),
         trail_offset = math.round(i_trailOff * shortStopDist / syminfo.mintick))

// ── EOD exit ─────────────────────────────────────────────────────────────────
if strategy.position_size != 0 and nyTotal >= 660
    strategy.close_all(comment="EOD")

// ── Plots ─────────────────────────────────────────────────────────────────────
plot(orbHigh, "ORB High", color=color.green, linewidth=1, style=plot.style_stepline)
plot(orbLow,  "ORB Low",  color=color.red,   linewidth=1, style=plot.style_stepline)
plot(vwap,    "VWAP",     color=color.blue,  linewidth=1)
bgcolor(inEntryWindow ? color.new(color.yellow, 95) : na, title="Entry Window")
